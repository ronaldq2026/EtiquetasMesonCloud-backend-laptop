// services/pos-dbf.service.js
const { DBFFile } = require('dbffile');

function norm(str) {
  return String(str ?? '').trim();
}

async function loadPosmapre(path) {
  const dbf = await DBFFile.open(path);
  const records = await dbf.readRecords();
  const bySku = new Map();

  for (const r of records) {
    const sku = norm(r.MAPCODIN);
    if (!sku) continue;

    bySku.set(sku, {
      sku,
      barra: r.MAPBARRA ? String(r.MAPBARRA).trim() : null,
      descripcionCorta: norm(r.MAPDESCC),
      descripcionLarga: norm(r.MAPDESCL),
      precioNeto: Number(r.MAPPRENT ?? 0),
      precioUnitario: Number(r.MAPREUNI ?? 0),
    });
  }

  return bySku;
}
async function loadPosdpofe(path) {
  console.log('[loadPosdpofe] Abriendo DBF en:', path);
  const dbf = await DBFFile.open(path);
  const records = await dbf.readRecords();
  const bySku = new Map();

  for (const r of records) {
    // *** IMPORTANTE: asumimos que DP_DATO es el SKU ***
    const sku = norm(r.DP_DATO);
    if (!sku) continue;

    bySku.set(sku, {
      sku,
      descripcionPromo: norm(r.DP_DESCRIP),
      vigenciaInicio: r.DP_FINICIO
        ? r.DP_FINICIO.toISOString().slice(0, 10)
        : null,
      vigenciaFin: r.DP_FFIN
        ? r.DP_FFIN.toISOString().slice(0, 10)
        : null,
      precioNormal: Number(r.DP_VALORIG ?? 0),
      precioOferta: Number(r.DP_VALOFER ?? 0),
      precioUnitario: Number(r.DP_P_UNIT ?? 0),
      descuentoPct: Number(r.DP_DSCTO ?? 0),
    });
  }

  console.log('[loadPosdpofe] Ofertas cargadas:', bySku.size);
  return bySku;
}

module.exports = { loadPosmapre, loadPosdpofe };
