// services/zebra.service.js
const net = require("net");
const fs = require("fs");
const os = require("os");
const path = require("path");
const { execFile } = require("child_process");
const printerConfig = require("../config/printer");

// etiquetas / textos (ajusta según tus .CH)
const LABELS = {
  LBL_037: "OFERTA",  // equiv a LBL_037 en CHI_ETIQUETAS.ch
  LBL_038: "HASTA ",  // equiv a LBL_038
  SIMBOLO_MONEDA: "$",
};

// ---- genera EPL equivalente al código VFP que mostraste
function buildEplEtiqueta({
  descripIzq,
  descripDer,
  precio,
  barra,
  fechaTermino,
  codigo,
  comision,
}) {
  const quote = '"';      // lvalor
  const eol = "\r\n";     // xhr

  descripIzq = (descripIzq || "").toString().trim();
  descripDer = (descripDer || "").toString().trim();
  precio = (precio || "").toString().trim();
  barra = (barra || "").toString().trim();
  fechaTermino = (fechaTermino || "").toString().trim();
  codigo = (codigo || "").toString().trim();
  comision = (comision || "").toString().trim();

  const lines = [
    "N",
    "Q590,B160+0",
    "R0,0",
    "S2",
    "D5",
    "ZB",
    `A630,81,1,4,3,3,N,${quote}${LABELS.LBL_037}${quote}`,
    `A590,391,1,1,2,1,N,${quote}${LABELS.LBL_038}${fechaTermino}${quote}`,
    `A550,3,1,2,4,2,N,${quote}${descripIzq}${quote}`,
    `A490,1,1,2,4,2,N,${quote}${descripDer}${quote}`,
    `A410,71,1,4,5,4,N,${quote}${LABELS.SIMBOLO_MONEDA}${quote}`,
    `A420,15,1,4,6,4,N,${quote}${precio}${quote}`,
    `A295,10,1,2,1,1,N,${quote}${codigo}${quote}`,
    `A270,580,1,2,1,1,N,${quote}${comision}${quote}`,
    `B295,171,1,E30,3,30,80,B,${quote}${barra}${quote}`,
    "P1",
  ];

  return lines.join(eol) + eol;
}

// ---- envío TCP (impresora con IP)
function sendEplTcp(epl) {
  const { zebraHost, zebraPort } = printerConfig;
  return new Promise((resolve, reject) => {
    const client = new net.Socket();
    client.connect(zebraPort, zebraHost, () => {
      client.write(epl, "utf8", () => client.end());
    });
    client.on("error", reject);
    client.on("close", resolve);
  });
}

// services/zebra.service.js (solo esta función)
function sendEplWindowsRaw(epl) {
  const { sharePath } = printerConfig;
  console.log(">> sendEplWindowsRaw sharePath:", sharePath);
  return new Promise((resolve, reject) => {
    const tempPath = path.join(os.tmpdir(), `label_${Date.now()}.epl`);
    fs.writeFileSync(tempPath, epl, "utf8");

    // copy /b "temp.epl" "\\localhost\flejes"
    const cmd = `copy /b "${tempPath}" "${sharePath}"`;
    const cmdPath = "C:\\Windows\\System32\\cmd.exe";

    execFile(cmdPath, ["/c", cmd], { windowsHide: true }, (error, stdout, stderr) => {
      // limpiar archivo temporal SIEMPRE
      fs.unlink(tempPath, () => {});
      if (error) {
        console.error("Error ejecutando copy:", error);
        return reject(error);
      }
      if (stderr) {
        console.warn("stderr de copy:", stderr);
      }
      resolve(stdout || stderr || "OK");
    });
  });
}

async function sendEtiqueta(epl) {
  if (printerConfig.mode === "tcp") return sendEplTcp(epl);
  if (printerConfig.mode === "windows-raw") return sendEplWindowsRaw(epl);
  throw new Error(`Modo de impresión no soportado: ${printerConfig.mode}`);
}

// ---- usa un producto de posmapre y arma la etiqueta
async function printEtiquetaOferta(producto) {
  const payload = {
    // AJUSTA estos campos a tu estructura real de posmapre
    descripIzq: producto.DESPROD || producto.DESCRIPCION || "",
    descripDer: "", // si no tienes campo "derecho", lo dejamos vacío
    precio: producto.PRECIO_OFERTA || producto.PRECIO || producto.PRECIO1,
    barra: producto.CODBARRA || producto.CODBAR || "",
    fechaTermino: producto.FEC_TERMINO || "",
    codigo: producto.CODPROD || producto.CODIGO || producto.COD,
    comision: producto.COMISION || "0",
  };

  const epl = buildEplEtiqueta(payload);
  return sendEtiqueta(epl);
}

module.exports = {
  printEtiquetaOferta,
};
``